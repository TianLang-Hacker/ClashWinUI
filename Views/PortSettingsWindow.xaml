<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ClashWinUI.Views.PortSettingsWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="TitleBarDragRegion"
            Height="40"
            Margin="0,0,0,8"
            Background="Transparent" />

        <StackPanel
            Grid.Row="1"
            Spacing="8">
            <TextBlock
                FontSize="20"
                FontWeight="SemiBold"
                Text="{Binding [PortSettingsWindowTitle], Source={StaticResource L}}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding [PortSettingsWindowDescription], Source={StaticResource L}}"
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid
            Grid.Row="2"
            Margin="0,20,0,0"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                Spacing="8">
                <TextBlock Text="{Binding [SettingsMixinMixedPortLabel], Source={StaticResource L}}" />
                <TextBox Text="{x:Bind Draft.MixedPortInput, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                Spacing="8">
                <TextBlock Text="{Binding [SettingsMixinHttpPortLabel], Source={StaticResource L}}" />
                <TextBox Text="{x:Bind Draft.HttpPortInput, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,12,0,0"
                Spacing="8">
                <TextBlock Text="{Binding [SettingsMixinSocksPortLabel], Source={StaticResource L}}" />
                <TextBox Text="{x:Bind Draft.SocksPortInput, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,12,0,0"
                Spacing="8">
                <TextBlock Text="{Binding [SettingsMixinRedirPortLabel], Source={StaticResource L}}" />
                <TextBox Text="{x:Bind Draft.RedirPortInput, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel
                Grid.Row="2"
                Grid.Column="0"
                Margin="0,12,0,0"
                Spacing="8">
                <TextBlock Text="{Binding [SettingsMixinTProxyPortLabel], Source={StaticResource L}}" />
                <TextBox Text="{x:Bind Draft.TProxyPortInput, Mode=TwoWay}" />
            </StackPanel>
        </Grid>

        <TextBlock
            Grid.Row="3"
            Margin="0,20,0,0"
            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
            Text="{x:Bind Draft.StatusMessage, Mode=OneWay}"
            TextWrapping="WrapWholeWords" />

        <StackPanel
            Grid.Row="4"
            Margin="0,24,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                x:Name="CancelButton"
                Click="CancelButton_Click"
                Content="{Binding [PortSettingsWindowCancelButton], Source={StaticResource L}}" />
            <Button
                x:Name="ConfirmButton"
                Click="ConfirmButton_Click"
                Content="{Binding [PortSettingsWindowConfirmButton], Source={StaticResource L}}" />
        </StackPanel>
    </Grid>
</Window>
