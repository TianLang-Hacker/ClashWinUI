<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ClashWinUI.Views.WelcomeWizardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ClashWinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Border
            Width="720"
            MinHeight="460"
            Padding="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Style="{StaticResource TitleTextBlockStyle}"
                        Text="{Binding [WelcomeWizardTitle], Source={StaticResource L}}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding [WelcomeWizardSubtitle], Source={StaticResource L}}" />
                </StackPanel>

                <Grid x:Name="PageContentHost" Grid.Row="1">
                    <StackPanel
                        x:Name="IntroPagePanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="34"
                            FontWeight="SemiBold"
                            Text="{Binding [WelcomeIntroTitle], Source={StaticResource L}}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        x:Name="ThemePagePanel"
                        Spacing="16"
                        Visibility="Collapsed">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{Binding [WelcomeThemeTitle], Source={StaticResource L}}" />

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding [ThemeModeLabel], Source={StaticResource L}}" />
                                <ComboBox
                                    Width="220"
                                    SelectedValue="{Binding SelectedAppThemeTag, Mode=TwoWay}"
                                    SelectedValuePath="Tag">
                                    <ComboBoxItem
                                        Content="{Binding [ThemeModeLight], Source={StaticResource L}}"
                                        Tag="light" />
                                    <ComboBoxItem
                                        Content="{Binding [ThemeModeDark], Source={StaticResource L}}"
                                        Tag="dark" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="{Binding [ThemeBackdropLabel], Source={StaticResource L}}" />
                                <ComboBox
                                    Width="220"
                                    SelectedValue="{Binding SelectedBackdropTag, Mode=TwoWay}"
                                    SelectedValuePath="Tag">
                                    <ComboBoxItem
                                        Content="{Binding [ThemeMica], Source={StaticResource L}}"
                                        Tag="mica" />
                                    <ComboBoxItem
                                        Content="{Binding [ThemeMicaAlt], Source={StaticResource L}}"
                                        Tag="mica_alt" />
                                    <ComboBoxItem
                                        Content="{Binding [ThemeAcrylic], Source={StaticResource L}}"
                                        Tag="acrylic" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding [LanguageHeader], Source={StaticResource L}}" />
                            <ComboBox
                                Width="220"
                                SelectedValue="{Binding SelectedLanguageTag, Mode=TwoWay}"
                                SelectedValuePath="Tag">
                                <ComboBoxItem
                                    Content="{Binding [LanguageEnglish], Source={StaticResource L}}"
                                    Tag="en-US" />
                                <ComboBoxItem
                                    Content="{Binding [LanguageSimplifiedChinese], Source={StaticResource L}}"
                                    Tag="zh-Hans" />
                                <ComboBoxItem
                                    Content="{Binding [LanguageTraditionalChinese], Source={StaticResource L}}"
                                    Tag="zh-Hant" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel
                        x:Name="KernelPagePanel"
                        Spacing="16"
                        Visibility="Collapsed">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{Binding [WelcomeKernelTitle], Source={StaticResource L}}" />

                        <RadioButton
                            Content="{Binding [WelcomeKernelOnline], Source={StaticResource L}}"
                            GroupName="KernelSource"
                            IsChecked="{Binding IsOnlineKernelSelected, Mode=TwoWay}" />
                        <RadioButton
                            Checked="CustomKernelRadioButton_Checked"
                            Content="{Binding [WelcomeKernelCustom], Source={StaticResource L}}"
                            GroupName="KernelSource"
                            IsChecked="{Binding IsCustomKernelSelected, Mode=OneWay}" />

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                IsEnabled="{Binding IsCustomKernelSelected}"
                                PlaceholderText="{Binding [KernelPathPlaceholder], Source={StaticResource L}}"
                                Text="{Binding CustomKernelPathInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                Click="BrowseKernelPathButton_Click"
                                Content="{Binding [KernelPathBrowseButton], Source={StaticResource L}}"
                                IsEnabled="{Binding IsCustomKernelSelected}" />
                        </Grid>

                        <TextBlock
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Text="{Binding KernelStatusMessage}"
                            TextWrapping="WrapWholeWords"
                            Visibility="{Binding KernelStatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>

                    <StackPanel
                        x:Name="ImportPagePanel"
                        Spacing="16"
                        Visibility="Collapsed">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{Binding [WelcomeImportTitle], Source={StaticResource L}}" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Click="ImportLocalFileButton_Click"
                                Content="{Binding [WelcomeImportLocal], Source={StaticResource L}}"
                                IsEnabled="{Binding CanImport}" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding [WelcomeImportUrlLabel], Source={StaticResource L}}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    PlaceholderText="{Binding [ProfilesSubscriptionUrlPlaceholder], Source={StaticResource L}}"
                                    Text="{Binding SubscriptionUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button
                                    Grid.Column="1"
                                    Command="{Binding ImportFromUrlCommand}"
                                    Content="{Binding [WelcomeImportUrl], Source={StaticResource L}}"
                                    IsEnabled="{Binding CanImport}" />
                            </Grid>
                        </StackPanel>

                        <ProgressRing
                            Width="22"
                            Height="22"
                            HorizontalAlignment="Left"
                            IsActive="{Binding IsBusy}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding ImportStatusMessage}"
                            TextWrapping="WrapWholeWords"
                            Visibility="{Binding ImportStatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>

                    <StackPanel
                        x:Name="DownloadPagePanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        Visibility="Collapsed">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{Binding [WelcomeDownloadTitle], Source={StaticResource L}}"
                            TextAlignment="Center" />
                        <ProgressBar Width="130" Value="{Binding DownloadProgressValue}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding DownloadProgressText}"
                            TextAlignment="Center" />
                        <TextBlock
                            Width="420"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding DownloadStatusMessage}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                        <Button
                            Command="{Binding RetryDownloadCommand}"
                            Content="{Binding [WelcomeRetryButton], Source={StaticResource L}}"
                            Visibility="{Binding ShowRetryButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <StackPanel
                        x:Name="CompletePagePanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        Visibility="Collapsed">
                        <TextBlock
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{Binding [WelcomeCompleteTitle], Source={StaticResource L}}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Grid>

                <StackPanel
                    x:Name="NavigationButtonsHost"
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Click="BackButton_Click"
                        Content="{Binding [WelcomeBackButton], Source={StaticResource L}}"
                        IsEnabled="{Binding CanGoBack}"
                        Visibility="{Binding ShowBackButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button
                        Click="SkipButton_Click"
                        Content="{Binding [WelcomeSkipButton], Source={StaticResource L}}"
                        IsEnabled="{Binding CanSkip}"
                        Visibility="{Binding ShowSkipButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button
                        Click="NextButton_Click"
                        Content="{Binding [WelcomeNextButton], Source={StaticResource L}}"
                        IsEnabled="{Binding CanGoNext}"
                        Style="{StaticResource AccentButtonStyle}"
                        Visibility="{Binding ShowNextButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button
                        Command="{Binding FinishCommand}"
                        Content="{Binding [WelcomeFinishButton], Source={StaticResource L}}"
                        IsEnabled="{Binding CanFinish}"
                        Style="{StaticResource AccentButtonStyle}"
                        Visibility="{Binding ShowFinishButton, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
