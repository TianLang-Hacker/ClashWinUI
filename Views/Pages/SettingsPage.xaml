<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashWinUI.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:ClashWinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d">
    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>
    <ScrollViewer>
        <Grid>
            <StackPanel
                MaxWidth="1000"
                HorizontalAlignment="Stretch"
                Spacing="{StaticResource SettingsCardSpacing}">
                <win:StackPanel.ChildrenTransitions>
                    <win:EntranceThemeTransition FromVerticalOffset="50" />
                    <win:RepositionThemeTransition IsStaggeringEnabled="False" />
                </win:StackPanel.ChildrenTransitions>

                <TextBlock
                    Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                    Text="{Binding [SettingsSection1], Source={StaticResource L}}" />

                <controls:SettingsCard
                    Description="{Binding [ThemeDescription], Source={StaticResource L}}"
                    Header="{Binding [ThemeHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding [ThemeModeLabel], Source={StaticResource L}}" />
                        <ComboBox
                            SelectedValuePath="Tag"
                            SelectedValue="{Binding SelectedAppThemeTag, Mode=TwoWay}">
                            <ComboBoxItem
                                Tag="system"
                                Content="{Binding [ThemeModeSystem], Source={StaticResource L}}" />
                            <ComboBoxItem
                                Tag="light"
                                Content="{Binding [ThemeModeLight], Source={StaticResource L}}" />
                            <ComboBoxItem
                                Tag="dark"
                                Content="{Binding [ThemeModeDark], Source={StaticResource L}}" />
                        </ComboBox>

                        <TextBlock Text="{Binding [ThemeBackdropLabel], Source={StaticResource L}}" />
                        <ComboBox
                            SelectedValuePath="Tag"
                            SelectedValue="{Binding SelectedBackdropTag, Mode=TwoWay}">
                            <ComboBoxItem
                                Tag="mica"
                                Content="{Binding [ThemeMica], Source={StaticResource L}}" />
                            <ComboBoxItem
                                Tag="mica_alt"
                                Content="{Binding [ThemeMicaAlt], Source={StaticResource L}}" />
                            <ComboBoxItem
                                Tag="acrylic"
                                Content="{Binding [ThemeAcrylic], Source={StaticResource L}}" />
                        </ComboBox>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Description="{Binding [LanguageDescription], Source={StaticResource L}}"
                    Header="{Binding [LanguageHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE909;}">
                    <ComboBox
                        SelectedValuePath="Tag"
                        SelectedValue="{Binding SelectedLanguageTag, Mode=TwoWay}">
                        <ComboBoxItem
                            Tag="en-US"
                            Content="{Binding [LanguageEnglish], Source={StaticResource L}}" />
                        <ComboBoxItem
                            Tag="zh-Hans"
                            Content="{Binding [LanguageSimplifiedChinese], Source={StaticResource L}}" />
                        <ComboBoxItem
                            Tag="zh-Hant"
                            Content="{Binding [LanguageTraditionalChinese], Source={StaticResource L}}" />
                    </ComboBox>
                </controls:SettingsCard>

                <TextBlock
                    Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                    Text="{Binding [SettingsSection2], Source={StaticResource L}}" />

                <controls:SettingsCard
                    Description="{Binding [CloseBehaviorDescription], Source={StaticResource L}}"
                    Header="{Binding [CloseBehaviorHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE8BB;}">
                    <ComboBox
                        SelectedValuePath="Tag"
                        SelectedValue="{Binding SelectedCloseBehaviorTag, Mode=TwoWay}">
                        <ComboBoxItem
                            Tag="minimize_to_tray"
                            Content="{Binding [CloseBehaviorMinimizeToTray], Source={StaticResource L}}" />
                        <ComboBoxItem
                            Tag="exit"
                            Content="{Binding [CloseBehaviorExit], Source={StaticResource L}}" />
                    </ComboBox>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Description="{Binding [ProxyGroupsExpandedByDefaultDescription], Source={StaticResource L}}"
                    Header="{Binding [ProxyGroupsExpandedByDefaultHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE70D;}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding [ProxyGroupsExpandedByDefaultToggleLabel], Source={StaticResource L}}" />
                        <ToggleSwitch IsOn="{Binding ProxyGroupsExpandedByDefault, Mode=TwoWay}" />
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Description="{Binding [KernelPathDescription], Source={StaticResource L}}"
                    Header="{Binding [KernelPathHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE838;}">
                    <StackPanel Spacing="10">
                        <TextBox
                            Text="{Binding KernelPathInput, Mode=TwoWay}"
                            PlaceholderText="{Binding [KernelPathPlaceholder], Source={StaticResource L}}" />

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                Click="BrowseKernelPathButton_Click"
                                Content="{Binding [KernelPathBrowseButton], Source={StaticResource L}}" />
                            <Button
                                Command="{Binding SaveKernelPathCommand}"
                                Content="{Binding [KernelPathSaveButton], Source={StaticResource L}}" />
                        </StackPanel>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Description="{Binding [GeoDataCardDescription], Source={StaticResource L}}"
                    Header="{Binding [GeoDataCardHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE745;}"
                    IsClickEnabled="True"
                    Tapped="UpdateGeoDataCard_Tapped">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{Binding IsUpdatingGeoData}"
                            Visibility="{Binding IsUpdatingGeoData, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock
                            Text="{Binding [GeoDataUpdatingLabel], Source={StaticResource L}}"
                            Visibility="{Binding IsUpdatingGeoData, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </controls:SettingsCard>

                <TextBlock
                    Margin="14,0,0,8"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding GeoDataStatusMessage}"
                    TextWrapping="WrapWholeWords"
                    Visibility="{Binding GeoDataStatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                <controls:SettingsCard
                    Description="{Binding [SettingsMixinDescription], Source={StaticResource L}}"
                    Header="{Binding [SettingsMixinHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}"
                    IsEnabled="{Binding HasActiveMixinProfile}">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding [SettingsMixinCurrentProfileLabel], Source={StaticResource L}}" />
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{Binding CurrentMixinProfileName}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding [SettingsMixinWorkspaceLabel], Source={StaticResource L}}" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding CurrentMixinWorkspacePath}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding MixinStatusMessage}"
                            TextWrapping="WrapWholeWords" />

                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    Grid.Column="0"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinAllowLanLabel], Source={StaticResource L}}" />
                                    <ToggleSwitch IsOn="{Binding AllowLanEnabled, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinIpv6Label], Source={StaticResource L}}" />
                                    <ToggleSwitch IsOn="{Binding Ipv6Enabled, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    Grid.Column="0"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinModeLabel], Source={StaticResource L}}" />
                                    <ComboBox
                                        SelectedValuePath="Tag"
                                        SelectedValue="{Binding SelectedModeTag, Mode=TwoWay}">
                                        <ComboBoxItem
                                            Tag="rule"
                                            Content="{Binding [SettingsMixinModeRule], Source={StaticResource L}}" />
                                        <ComboBoxItem
                                            Tag="global"
                                            Content="{Binding [SettingsMixinModeGlobal], Source={StaticResource L}}" />
                                        <ComboBoxItem
                                            Tag="direct"
                                            Content="{Binding [SettingsMixinModeDirect], Source={StaticResource L}}" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinLogLevelLabel], Source={StaticResource L}}" />
                                    <ComboBox
                                        SelectedValuePath="Tag"
                                        SelectedValue="{Binding SelectedLogLevelTag, Mode=TwoWay}">
                                        <ComboBoxItem
                                            Tag="debug"
                                            Content="{Binding [SettingsMixinLogLevelDebug], Source={StaticResource L}}" />
                                        <ComboBoxItem
                                            Tag="info"
                                            Content="{Binding [SettingsMixinLogLevelInfo], Source={StaticResource L}}" />
                                        <ComboBoxItem
                                            Tag="warning"
                                            Content="{Binding [SettingsMixinLogLevelWarning], Source={StaticResource L}}" />
                                        <ComboBoxItem
                                            Tag="error"
                                            Content="{Binding [SettingsMixinLogLevelError], Source={StaticResource L}}" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    Command="{Binding OpenMixinFolderCommand}"
                                    Content="{Binding [SettingsMixinOpenFolderButton], Source={StaticResource L}}" />
                                <Button
                                    Click="OpenPortSettingsButton_Click"
                                    Content="{Binding [SettingsMixinPortSettingsButton], Source={StaticResource L}}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Header="{Binding [SettingsTunCardHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE705;}"
                    IsEnabled="{Binding HasActiveMixinProfile}">
                    <controls:SettingsCard.Description>
                        <StackPanel Spacing="2">
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding [SettingsTunCardDescription], Source={StaticResource L}}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Text="{Binding TunRuntimeStatusText}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{Binding TunRuntimeStatusText, Converter={StaticResource StringToVisibilityConverter}}" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding TunRuntimeSummaryText}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{Binding TunRuntimeSummaryText, Converter={StaticResource StringToVisibilityConverter}}" />
                        </StackPanel>
                    </controls:SettingsCard.Description>

                    <ToggleSwitch IsOn="{Binding TunEnabled, Mode=TwoWay}" />
                </controls:SettingsCard>

                <TextBlock 
                    Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                    Text="{Binding [SettingsSectionUpdates], Source={StaticResource L}}" />

                <controls:SettingsCard Description="{Binding [SettingsUpdateCardDescription], Source={StaticResource L}}"
                                       Header="{Binding UpdateStatusHeader}"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE895;}">
                    <StackPanel Spacing="8">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                            <ProgressRing
                                Width="20"
                                Height="20"
                                IsActive="{Binding IsCheckingForUpdates}"
                                Visibility="{Binding IsCheckingForUpdates, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Command="{Binding CheckForUpdatesCommand}"
                                    Content="{Binding [SettingsUpdateCheckButton], Source={StaticResource L}}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Visibility="{Binding ShowUpdateDownloadProgress, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />
                        </StackPanel>

                        <StackPanel
                            Spacing="6"
                            Visibility="{Binding ShowUpdateDownloadProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ProgressBar
                                Height="4"
                                IsIndeterminate="{Binding IsUpdateDownloadProgressIndeterminate}"
                                Maximum="100"
                                Value="{Binding UpdateDownloadProgressValue}" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding UpdateDownloadProgressText}" />
                        </StackPanel>
                    </StackPanel>
                </controls:SettingsCard>

                <TextBlock
                    Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                    Text="{Binding [SettingsSectionAbout], Source={StaticResource L}}" />

                <controls:SettingsCard Description="TianLang Hacker (C) 2026. All rights reserved."
                                       Header="ClashWinUI"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE716;}">
                    <TextBlock
                        win:IsTextSelectionEnabled="True"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding CurrentAppVersionText}" />
                </controls:SettingsCard>

                <controls:SettingsExpander
                    Header="{Binding [SettingsThirdPartyLibrariesHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard
                            HorizontalContentAlignment="Left"
                            ContentAlignment="Left">
                            <StackPanel
                                Margin="-12,0,0,0"
                                Orientation="Vertical"
                                Spacing="2">
                                <HyperlinkButton
                                    Content="CommunityToolkit.Mvvm"
                                    NavigateUri="https://github.com/CommunityToolkit/dotnet" />
                                <HyperlinkButton
                                    Content="CommunityToolkit.WinUI.Controls.SettingsControls"
                                    NavigateUri="https://github.com/CommunityToolkit/Windows" />
                                <HyperlinkButton
                                    Content="H.NotifyIcon.WinUI"
                                    NavigateUri="https://github.com/HavenDV/H.NotifyIcon" />
                                <HyperlinkButton
                                    Content="LiveChartsCore.SkiaSharpView.WinUI"
                                    NavigateUri="https://github.com/beto-rodriguez/LiveCharts2" />
                                <HyperlinkButton
                                    Content="Microsoft.Extensions.DependencyInjection"
                                    NavigateUri="https://github.com/dotnet/runtime" />
                                <HyperlinkButton
                                    Content="Microsoft.Extensions.Hosting"
                                    NavigateUri="https://github.com/dotnet/runtime" />
                                <HyperlinkButton
                                    Content="Microsoft.Windows.SDK.BuildTools"
                                    NavigateUri="https://github.com/microsoft/WindowsAppSDK" />
                                <HyperlinkButton
                                    Content="Microsoft.WindowsAppSDK"
                                    NavigateUri="https://github.com/microsoft/WindowsAppSDK" />
                                <HyperlinkButton
                                    Content="Microsoft.WindowsAppSDK.WinUI"
                                    NavigateUri="https://github.com/microsoft/WindowsAppSDK" />
                                <HyperlinkButton
                                    Content="YamlDotNet"
                                    NavigateUri="https://github.com/aaubry/YamlDotNet" />
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
