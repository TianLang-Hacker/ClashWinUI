<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashWinUI.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d">
    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>

        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>
    <ScrollViewer>
        <Grid>
            <StackPanel
                MaxWidth="1000"
                HorizontalAlignment="Stretch"
                Spacing="{StaticResource SettingsCardSpacing}">
                <win:StackPanel.ChildrenTransitions>
                    <win:EntranceThemeTransition FromVerticalOffset="50" />
                    <win:RepositionThemeTransition IsStaggeringEnabled="False" />
                </win:StackPanel.ChildrenTransitions>

                <TextBlock
                    Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                    Text="{Binding [SettingsSection1], Source={StaticResource L}}" />

                <controls:SettingsCard
                    Description="{Binding [ThemeDescription], Source={StaticResource L}}"
                    Header="{Binding [ThemeHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding [ThemeModeLabel], Source={StaticResource L}}" />
                        <ComboBox
                            SelectedValuePath="Tag"
                            SelectedValue="{Binding SelectedAppThemeTag, Mode=TwoWay}">
                            <ComboBoxItem
                                Tag="system"
                                Content="{Binding [ThemeModeSystem], Source={StaticResource L}}" />
                            <ComboBoxItem
                                Tag="light"
                                Content="{Binding [ThemeModeLight], Source={StaticResource L}}" />
                            <ComboBoxItem
                                Tag="dark"
                                Content="{Binding [ThemeModeDark], Source={StaticResource L}}" />
                        </ComboBox>

                        <TextBlock Text="{Binding [ThemeBackdropLabel], Source={StaticResource L}}" />
                        <ComboBox
                            SelectedValuePath="Tag"
                            SelectedValue="{Binding SelectedBackdropTag, Mode=TwoWay}">
                            <ComboBoxItem
                                Tag="mica"
                                Content="{Binding [ThemeMica], Source={StaticResource L}}" />
                            <ComboBoxItem
                                Tag="mica_alt"
                                Content="{Binding [ThemeMicaAlt], Source={StaticResource L}}" />
                            <ComboBoxItem
                                Tag="acrylic"
                                Content="{Binding [ThemeAcrylic], Source={StaticResource L}}" />
                        </ComboBox>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Description="{Binding [LanguageDescription], Source={StaticResource L}}"
                    Header="{Binding [LanguageHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE909;}">
                    <ComboBox
                        SelectedValuePath="Tag"
                        SelectedValue="{Binding SelectedLanguageTag, Mode=TwoWay}">
                        <ComboBoxItem
                            Tag="en-US"
                            Content="{Binding [LanguageEnglish], Source={StaticResource L}}" />
                        <ComboBoxItem
                            Tag="zh-Hans"
                            Content="{Binding [LanguageSimplifiedChinese], Source={StaticResource L}}" />
                    </ComboBox>
                </controls:SettingsCard>

                <TextBlock
                    Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                    Text="{Binding [SettingsSection2], Source={StaticResource L}}" />

                <controls:SettingsCard
                    Description="{Binding [CloseBehaviorDescription], Source={StaticResource L}}"
                    Header="{Binding [CloseBehaviorHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE8BB;}">
                    <ComboBox
                        SelectedValuePath="Tag"
                        SelectedValue="{Binding SelectedCloseBehaviorTag, Mode=TwoWay}">
                        <ComboBoxItem
                            Tag="minimize_to_tray"
                            Content="{Binding [CloseBehaviorMinimizeToTray], Source={StaticResource L}}" />
                        <ComboBoxItem
                            Tag="exit"
                            Content="{Binding [CloseBehaviorExit], Source={StaticResource L}}" />
                    </ComboBox>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Description="{Binding [KernelPathDescription], Source={StaticResource L}}"
                    Header="{Binding [KernelPathHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE838;}">
                    <StackPanel Spacing="10">
                        <TextBox
                            Text="{Binding KernelPathInput, Mode=TwoWay}"
                            PlaceholderText="{Binding [KernelPathPlaceholder], Source={StaticResource L}}" />

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                Click="BrowseKernelPathButton_Click"
                                Content="{Binding [KernelPathBrowseButton], Source={StaticResource L}}" />
                            <Button
                                Command="{Binding SaveKernelPathCommand}"
                                Content="{Binding [KernelPathSaveButton], Source={StaticResource L}}" />
                        </StackPanel>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Description="{Binding [SettingsMixinDescription], Source={StaticResource L}}"
                    Header="{Binding [SettingsMixinHeader], Source={StaticResource L}}"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}"
                    IsEnabled="{Binding HasActiveMixinProfile}">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding [SettingsMixinCurrentProfileLabel], Source={StaticResource L}}" />
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{Binding CurrentMixinProfileName}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding [SettingsMixinWorkspaceLabel], Source={StaticResource L}}" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding CurrentMixinWorkspacePath}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding MixinStatusMessage}"
                            TextWrapping="WrapWholeWords" />

                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    Grid.Column="0"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinMixedPortLabel], Source={StaticResource L}}" />
                                    <TextBox Text="{Binding MixedPortInput, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinHttpPortLabel], Source={StaticResource L}}" />
                                    <TextBox Text="{Binding HttpPortInput, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinSocksPortLabel], Source={StaticResource L}}" />
                                    <TextBox Text="{Binding SocksPortInput, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    Grid.Column="0"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinRedirPortLabel], Source={StaticResource L}}" />
                                    <TextBox Text="{Binding RedirPortInput, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinTProxyPortLabel], Source={StaticResource L}}" />
                                    <TextBox Text="{Binding TProxyPortInput, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    Grid.Column="0"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinTunEnabledLabel], Source={StaticResource L}}" />
                                    <ToggleSwitch IsOn="{Binding TunEnabled, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinAllowLanLabel], Source={StaticResource L}}" />
                                    <ToggleSwitch IsOn="{Binding AllowLanEnabled, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinIpv6Label], Source={StaticResource L}}" />
                                    <ToggleSwitch IsOn="{Binding Ipv6Enabled, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    Grid.Column="0"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinModeLabel], Source={StaticResource L}}" />
                                    <ComboBox
                                        SelectedValuePath="Tag"
                                        SelectedValue="{Binding SelectedModeTag, Mode=TwoWay}">
                                        <ComboBoxItem
                                            Tag="rule"
                                            Content="{Binding [SettingsMixinModeRule], Source={StaticResource L}}" />
                                        <ComboBoxItem
                                            Tag="global"
                                            Content="{Binding [SettingsMixinModeGlobal], Source={StaticResource L}}" />
                                        <ComboBoxItem
                                            Tag="direct"
                                            Content="{Binding [SettingsMixinModeDirect], Source={StaticResource L}}" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="8">
                                    <TextBlock Text="{Binding [SettingsMixinLogLevelLabel], Source={StaticResource L}}" />
                                    <ComboBox
                                        SelectedValuePath="Tag"
                                        SelectedValue="{Binding SelectedLogLevelTag, Mode=TwoWay}">
                                        <ComboBoxItem
                                            Tag="debug"
                                            Content="{Binding [SettingsMixinLogLevelDebug], Source={StaticResource L}}" />
                                        <ComboBoxItem
                                            Tag="info"
                                            Content="{Binding [SettingsMixinLogLevelInfo], Source={StaticResource L}}" />
                                        <ComboBoxItem
                                            Tag="warning"
                                            Content="{Binding [SettingsMixinLogLevelWarning], Source={StaticResource L}}" />
                                        <ComboBoxItem
                                            Tag="error"
                                            Content="{Binding [SettingsMixinLogLevelError], Source={StaticResource L}}" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    Command="{Binding OpenMixinFolderCommand}"
                                    Content="{Binding [SettingsMixinOpenFolderButton], Source={StaticResource L}}" />
                                <Button
                                    Command="{Binding ApplyMixinCommand}"
                                    Content="{Binding [SettingsMixinApplyButton], Source={StaticResource L}}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </controls:SettingsCard>

                <TextBlock
                    Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                    Text="About" />

                <controls:SettingsExpander
                    Description="(C) 2026. All rights reserved."
                    Header="Community Toolkit Gallery"
                    HeaderIcon="{ui:BitmapIcon Source=ms-appx:///Assets/AppTitleBar.scale-200.png}">
                    <TextBlock
                        win:IsTextSelectionEnabled="True"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Version 8.0.0" />
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard
                            HorizontalContentAlignment="Left"
                            ContentAlignment="Left">
                            <StackPanel
                                Margin="-12,0,0,0"
                                Orientation="Vertical">
                                <HyperlinkButton Content="Link 1" />
                                <HyperlinkButton Content="Link 2" />
                                <HyperlinkButton Content="Link 3" />
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>
                <HyperlinkButton
                    Margin="0,8,0,0"
                    Content="Send feedback" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
