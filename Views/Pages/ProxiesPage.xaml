<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClashWinUI.Views.Pages.ProxiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ClashWinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ClashWinUI.Models"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:ProxyDelayLevelToBrushConverter x:Key="ProxyDelayLevelToBrushConverter" />
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="24,24,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center">
                <Button
                    Command="{Binding RefreshCommand}"
                    Content="{Binding [ProxiesRefreshButton], Source={StaticResource L}}" />
                <Button
                    Command="{Binding TestSelectedCommand}"
                    Content="{Binding [ProxiesTestSelectedButton], Source={StaticResource L}}" />
                <Button
                    Command="{Binding TestAllCommand}"
                    Content="{Binding [ProxiesTestAllButton], Source={StaticResource L}}" />
            </StackPanel>
        </Grid>

        <StackPanel
            Grid.Row="1"
            Margin="24,0,24,12"
            Spacing="8">
            <TextBox
                Text="{Binding TestUrl, Mode=TwoWay}"
                PlaceholderText="{Binding [ProxiesTestUrlPlaceholder], Source={StaticResource L}}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding StatusMessage, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Border
            Grid.Row="2"
            Margin="24,0,24,24"
            Padding="4"
            CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <ListView
                ItemsSource="{Binding Nodes}"
                SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                BorderThickness="0"
                HorizontalContentAlignment="Stretch"
                Background="Transparent">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProxyNode">
                        <Grid Margin="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Name}" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding Type}" />
                            <TextBlock
                                Grid.Column="2"
                                Text="{Binding DelayText}"
                                Foreground="{Binding DelayLevel, Converter={StaticResource ProxyDelayLevelToBrushConverter}}"
                                HorizontalAlignment="Right" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
